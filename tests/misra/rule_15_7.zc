// MISRA Rule 15.7: All if ... else if constructs shall be terminated with an else statement.
// EXPECT: MISRA Rule 15.7

fn main() {
    let a = 1;
    let b = 2;

    if a == 1 {
        // ...
    } else if b == 2 {
        // ...
    } // FAIL: Missing else
    
    if a == 1 {
        // ...
    } else if b == 2 {
        // ...
    } else {
        // ...
    } // PASS
}
