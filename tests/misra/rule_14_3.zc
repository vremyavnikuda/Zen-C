// MISRA Rule 14.3 Verification
// EXPECT: MISRA Rule 14.3
// EXPECT: MISRA Rule 14.3
// EXPECT: MISRA Rule 14.3

fn test_misra_invariant_while() {
    let i = 0;
    while (1) { // Violation (Invariant)
        if (i == 0) {
            break;
        }
    }
}

fn test_misra_invariant_for() {
    for (; 1; ) { // Violation (Invariant)
        break;
    }
}

fn test_misra_invariant_do_while() {
    do {
        break;
    } while (0); // Violation (Invariant)
}

fn main() {
    test_misra_invariant_while();
    test_misra_invariant_for();
    test_misra_invariant_do_while();
}
