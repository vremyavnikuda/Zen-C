// MISRA Rule 10.1 Verification
// EXPECT: MISRA Rule 10.1
// EXPECT: MISRA Rule 10.1

fn test_misra_bitwise_fail_signed() {
    let a: i32 = 10;
    let b: i32 = 20;
    // Violation: Bitwise operator with signed operand
    let _c = a & b; 
}

fn test_misra_bitwise_fail_not() {
    let a: i32 = 10;
    // Violation: Bitwise NOT with signed operand
    let _h = ~a; 
}

fn main() {
    test_misra_bitwise_fail_signed();
    test_misra_bitwise_fail_not();
}
